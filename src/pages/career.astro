---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Career - Steve Wang"
  description="Outcome-focused career profile for Steve Wang across full-stack development, automation, reporting, and purchasing systems."
  current="career"
>
  <main>
    <section class="page-title section-wrap">
      <h1>Career</h1>
      <p>
        Full-stack development and automation work shaped by production CMS engineering,
        payment integrations, CI/CD, and hands-on purchasing operations.
      </p>
    </section>

    <section class="section-wrap career-layout">
      <div class="timeline">
        <article>
          <span>Developer</span>
          <h2>Full-stack CMS and platform engineering</h2>
          <p>Built and maintained a digital signage CMS with permissions, Stripe payment setup, CI/CD, templates, and a built-in editor.</p>
        </article>
        <article>
          <span>Ownership</span>
          <h2>Sole developer for production systems</h2>
          <p>Handled database design and maintenance, frontend and backend delivery, Electron and TV app maintenance, production issues, and coordination with outsourced development support.</p>
        </article>
        <article>
          <span>Current domain</span>
          <h2>Purchasing operations in foodservice supply</h2>
          <p>Work with stock checks, purchase orders, supplier credit claims, rebate calculations, transport booking, and cost or price updates.</p>
        </article>
        <article>
          <span>Outcome</span>
          <h2>Built practical Python automation</h2>
          <p>Use scripts to reduce repetitive spreadsheet work and practice turning daily operations into clearer workflows.</p>
        </article>
        <article>
          <span>Direction</span>
          <h2>Building toward systems and automation roles</h2>
          <p>Focused on software development, automation engineering, supply chain systems, procurement tooling, and a long-term path toward technical leadership or architecture.</p>
        </article>
      </div>

      <aside class="skill-panel">
        <h2>Technical Profile</h2>
        <div class="skill-group">
          <h3>Core Engineering</h3>
          <p>Python, JavaScript, TypeScript, React, Node.js, REST APIs, authentication, role-based access control.</p>
        </div>
        <div class="skill-group">
          <h3>Backend &amp; Data</h3>
          <p>MySQL, SQLite, schema design, migrations, CSV/Excel automation, Pandas, NumPy, Swagger/OpenAPI.</p>
        </div>
        <div class="skill-group">
          <h3>Production Systems</h3>
          <p>AWS Amplify, AWS EC2, S3, Route 53/DNS, Linux, Bash, Docker, Nginx, GitHub Actions, CircleCI, Bitbucket Pipelines.</p>
        </div>
        <div class="skill-group">
          <h3>Product Integrations</h3>
          <p>Stripe payments, subscription/license workflows, API integrations, email notifications, scheduled jobs, monitoring, releases.</p>
        </div>
        <div class="skill-group">
          <h3>Interface &amp; Devices</h3>
          <p>Admin dashboards, CMS development, digital signage, device/screen management, Electron, responsive UI, charting, React Testing Library.</p>
        </div>
        <a class="button button-primary" href="/projects/">See project evidence</a>
      </aside>
    </section>

    <section class="section-wrap operations-section">
      <div class="section-heading">
        <h2>Operations Domain</h2>
      </div>
      <div class="operations-grid">
        <article>
          <h3>Purchasing Workflow</h3>
          <p>Purchase order processing, supplier communication, stock review, low-stock ordering, and internal system data maintenance.</p>
        </article>
        <article>
          <h3>Claims &amp; Commercial Tracking</h3>
          <p>Supplier credit claims, rebate calculation, cost changes, price updates, margin/markup checks, and reconciliation.</p>
        </article>
        <article>
          <h3>Sales &amp; Category Reporting</h3>
          <p>Sales/category reporting, customer purchase trends, lost customer checks, promotion review, and inventory trends.</p>
        </article>
        <article>
          <h3>Logistics Support</h3>
          <p>Transport booking, supplier follow-up, order coordination, and practical workflow design around foodservice supply operations.</p>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
